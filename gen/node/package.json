{
  "name": "@protobuf/contracts-node",
  "version": "1.0.0",
  "description": "Node.js CommonJS bindings for Protobuf Contracts protobuf schemas (generated by protoc-gen-js)",
  "type": "commonjs",
  "main": "./transaction_pb.js",
  "types": "./transaction_pb.d.ts",
  "exports": {
    ".": {
      "require": "./transaction_pb.js",
      "types": "./transaction_pb.d.ts"
    }
  },
  "files": [
    "transaction_pb.js",
    "transaction_pb.d.ts"
  ],
  "keywords": ["protobuf", "contracts", "protobuf", "kafka", "node"],
  "license": "MIT",
  "peerDependencies": {
    "google-protobuf": "^3.21.2"
  }
}
