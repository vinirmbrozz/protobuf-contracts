{
  "name": "@truther/contracts",
  "version": "1.0.0",
  "description": "Truther Contracts SDK — generated Protobuf types + Confluent SR serde for Node/TS",
  "type": "commonjs",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "prepare": "tsc",
    "test": "jest --testPathPattern='unit'",
    "test:unit": "jest --testPathPattern='unit'",
    "test:integration": "jest --testPathPattern='integration' --testTimeout=60000",
    "lint": "tsc --noEmit"
  },
  "keywords": [
    "truther",
    "kafka",
    "serde",
    "confluent",
    "schema-registry",
    "protobuf"
  ],
  "license": "MIT",
  "dependencies": {
    "@bufbuild/protobuf": "^2.0.0"
  },
  "devDependencies": {
    "@types/google-protobuf": "^3.15.12",
    "@types/jest": "^29.5.14",
    "@types/node": "^20.19.41",
    "jest": "^29.7.0",
    "ts-jest": "^29.4.11",
    "typescript": "^5.9.3"
  }
}
